            "path": "@.value",
            "label": "Delegated amount",
            "format": "amount",
            "visible": "always"
          }
        ]
      },
      "undelegate(address withdrawalAddress, uint256 shares)": {
        "intent": "Undelegate",
        "fields": [
          {
            "path": "@.to",
            "label": "Validator address",
            "format": "addressName",
            "params": { "types": ["contract"] },
            "visible": "always"
          },
          {
            "path": "#.withdrawalAddress",
            "label": "Withdrawal address",
            "format": "addressName",
            "params": { "types": ["eoa"] },
            "visible": "always"
          },
          {
            "path": "#.shares",
            "label": "Undelegated shares",
            "format": "unit",
            "params": { "base": "shares", "decimals": 18 },
            "visible": "always"
          },
          {
            "path": "@.value",
            "label": "Validator fees",
            "format": "amount",
            "visible": "always"
          }
        ]
      },
